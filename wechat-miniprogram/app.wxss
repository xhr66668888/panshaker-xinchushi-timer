page {
  background-color: #008080;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  width: 100%;
  max-width: 650rpx;
  background: #c0c0c0;
  border: 4rpx solid;
  border-color: #ffffff #808080 #808080 #ffffff;
  margin-bottom: 24rpx;
}

.card-title {
  background: linear-gradient(90deg, #000080, #1084d0);
  color: #ffffff;
  padding: 8rpx 16rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.card-body {
  padding: 20rpx;
}

.field-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.field-label {
  width: 140rpx;
  text-align: right;
  margin-right: 16rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 56rpx;
  border: 2rpx solid;
  border-color: #808080 #ffffff #ffffff #808080;
  background: #ffffff;
  padding: 0 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.field-picker {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  border: 2rpx solid;
  border-color: #808080 #ffffff #ffffff #808080;
  background: #ffffff;
  padding: 0 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.btn-row {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn {
  min-width: 140rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 24rpx;
  background: #c0c0c0;
  border: 4rpx solid;
  border-color: #ffffff #808080 #808080 #ffffff;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.btn-primary {
  font-weight: bold;
}

.btn:active, .btn.btn-active {
  border-color: #808080 #ffffff #ffffff #808080;
}

.msg {
  text-align: center;
  font-size: 24rpx;
  margin-top: 12rpx;
}

.msg-error { color: red; }
.msg-success { color: green; }

.link-btn {
  color: blue;
  font-size: 24rpx;
  text-decoration: underline;
  background: none;
  border: none;
  padding: 0;
}

/* Table styles */
.table-wrap {
  border: 2rpx solid;
  border-color: #808080 #ffffff #ffffff #808080;
  background: #ffffff;
  max-height: 400rpx;
  overflow-y: auto;
}

.table-header {
  display: flex;
  background: #c0c0c0;
  border-bottom: 2rpx solid #808080;
  position: sticky;
  top: 0;
  z-index: 1;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #e0e0e0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  padding: 8rpx 10rpx;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-header .table-cell {
  font-weight: bold;
  font-size: 22rpx;
}

.total-row {
  display: flex;
  background: #ffffca;
  font-weight: bold;
  border-top: 2rpx solid #808080;
}
