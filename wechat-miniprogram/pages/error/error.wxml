<view class="container">
  <view class="panel">
    <view class="title">网页加载失败</view>
    <view class="desc">请确认微信后台已配置业务域名：</view>
    <view class="domain">panshaker-timer.azurewebsites.net</view>

    <button type="primary" bindtap="retry">重试</button>
    <button bindtap="goHome">返回登录页</button>
    <button bindtap="copyFailedUrl">复制失败链接</button>
  </view>
</view>
